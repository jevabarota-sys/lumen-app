default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Set up environment
    setup_ci if ENV['CI']
    
    # Get App Store Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_filepath: ENV['APP_STORE_CONNECT_API_KEY_PATH'],
      duration: 1200,
      in_house: false
    )
    
    # Sync certificates and provisioning profiles using match
    match(
      type: "appstore",
      app_identifier: "com.growwithlumen.app",
      readonly: true,
      api_key: api_key
    )
    
    # Increment build number
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.growwithlumen.app"
      ) + 1
    )
    
    # Build the app with Flutter
    sh("flutter", "build", "ios", "--release",
       "--dart-define=SUPABASE_URL=#{ENV['SUPABASE_URL']}",
       "--dart-define=SUPABASE_ANON_KEY=#{ENV['SUPABASE_ANON_KEY']}")
    
    # Build and sign the IPA
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.growwithlumen.app" => "match AppStore com.growwithlumen.app"
        }
      }
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
  
  desc "Register new devices for development"
  lane :register_devices do
    register_devices(
      devices_file: "./fastlane/devices.txt"
    )
  end
end
